#!/usr/bin/env php
<?php

// LIVE ONLY: 
require __DIR__ . '/../../../../vendor/autoload.php';

$args = $argv;
$command = $args[1] ?? 'help';

switch ($command) {
    case 'make':
        (new \ApiCrumbs\Core\Commands\MakeCommand())->handle($args);
        break;
    case 'install':
        (new \ApiCrumbs\Core\Commands\InstallCommand())->handle($args);
        break;
    case 'list':
        (new \ApiCrumbs\Core\Commands\ListCommand())->handle($args);
        break;
    case 'linter':
        (new \ApiCrumbs\Core\Commands\LinterCommand())->handle();
        break;
    case 'update':
        (new \ApiCrumbs\Core\Commands\UpdateCommand())->handle($argv);
        break;
    default:
        echo "\e[1;34m🍪 ApiCrumbs Foundry CLI\e[0m\n";
        echo "Usage: php foundry [command] [options]\n\n";
        echo "  \e[32mlist\e[0m             List all available 250+ providers\n";
        echo "  \e[32minstall [Path]\e[0m   Download a free provider\n";
        echo "  \e[32mlinter\e[0m           Checks providers architectural linting\n";
        echo "  \e[32mupdate\e[0m           Synchronises local providers with the remote  providers\n";
        echo "  \e[32mmake [Name]\e[0m      Create a custom provider stub\n";
        break;
}
