#!/usr/bin/env php
<?php

// LIVE ONLY: 
require __DIR__ . '/../../../../vendor/autoload.php';


$args = $argv;
$command = $args[1] ?? 'help';

switch ($command) {
    case 'setup:ssl':
        (new \ApiCrumbs\Core\Commands\SslSetupCommand())->handle();
        break;
    case 'make':
        (new \ApiCrumbs\Core\Commands\MakeCommand())->handle($args);
        break;
    case 'install':
        (new \ApiCrumbs\Core\Commands\InstallCommand())->handle($args);
        break;
    case 'list':
        (new \ApiCrumbs\Core\Commands\ListCommand())->handle($args);
        break;
    case 'linter':
        (new \ApiCrumbs\Core\Commands\LinterCommand())->handle();
        break;
    case 'update':
        (new \ApiCrumbs\Core\Commands\UpdateCommand())->handle($argv);
        break;
    case 'logs':
        (new \ApiCrumbs\Core\Commands\LogsCommand())->handle($args);
        break;
    case 'preview':
        (new \ApiCrumbs\Core\Commands\PreviewCommand())->handle($args);
        break;
    case 'setup:all':
        // The "Onboarding Master": Runs SSL, Env, and Doctor in sequence
        (new SetupAllCommand())->handle();
        break;
    default:
        renderHelp();
        break;
}

function renderHelp() 
{
    echo "\e[1;36m🍪 ApiCrumbs Foundry CLI\e[0m\n";
    echo "Usage: php foundry [command] [options]\n\n";
    echo "\e[1mOnboarding:\e[0m\n";
    echo "  setup:all      Run full environment setup (SSL + .env + Doctor)\n";
    echo "  setup:ssl      Solve the common ``URL error 60`` issue on Windows/XAMPP\n";
    echo "  doctor         Check system health and XAMPP SSL status\n\n";
    echo "\e[1mRegistry:\e[0m\n";
    echo "  update         Sync local 'Crumbs' with remote Registry (--dry-run available)\n";
    echo "  graph          View dependency lineage (--mermaid available)\n\n";
    echo "\e[1mDevelopment:\e[0m\n";
    echo "  make [Name]    Scaffold a new Provider (--csv|--pro flags available)\n";
    echo "  linter         Validate architecture and key naming consistency\n";
}